# Copy to .env for local development.
# Every knob the app reads gets a line here -- it's the single source of
# truth for configuration.

# --- Core -------------------------------------------------------------
ENVIRONMENT=development

# Async SQLAlchemy URL. Default lands the dev DB next to the repo root.
# DATABASE_URL=sqlite+aiosqlite:///./fleetwise.db

# CORS allow-list (comma-separated). Defaults cover Angular :4200 and
# Vite :5173 for local dev.
# CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:5173

# --- AI / LangGraph ---------------------------------------------------
# Flip between Anthropic, OpenAI, and Ollama. Each provider's key lives
# in its own block below -- only the active one needs to be populated.
AI_PROVIDER=anthropic

# Anthropic (default for the hosted demo).
# ANTHROPIC_API_KEY=
# ANTHROPIC_CHAT_MODEL=claude-sonnet-4-5

# OpenAI (fallback chat + embedding source for Phase 5 RAG).
# OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4o-mini

# Ollama (local, free, no key). Endpoint matches the out-of-box listener.
# OLLAMA_ENDPOINT=http://localhost:11434
# OLLAMA_CHAT_MODEL=llama3.2

# LangGraph checkpointer. SQLite file keeps conversation history across
# restarts. Render overrides with a volume-mounted path.
# CHECKPOINT_DB_PATH=./checkpoints.db

# --- RAG (Phase 5) ----------------------------------------------------
# Markdown SOP documents live here. One-time ingestion on first boot
# populates the Chroma collection; subsequent boots skip the work.
# DOCUMENTS_DIR=./data/documents

# Chroma's persistent directory. Render mounts this on the same volume
# as the fleet DB and the checkpoint store.
# CHROMA_PERSIST_DIR=./data/chroma
# CHROMA_COLLECTION_NAME=fleet-documents

# Embedding provider. `auto` picks OpenAI if OPENAI_API_KEY is set, else
# Ollama's nomic-embed-text. `disabled` turns RAG off (the agent won't
# advertise search_fleet_documentation). Anthropic has no embedding API,
# so even with AI_PROVIDER=anthropic you need OpenAI or Ollama for RAG.
# EMBEDDING_PROVIDER=auto
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
