# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# Virtual environments
.venv/
venv/
env/

# uv
# keep uv.lock committed; ignore nothing extra

# Env files
.env
.env.local
.env.*.local

# Editors / OS
# .vscode/ is committed -- it pins the interpreter and formatter for consistency.
.idea/
*.swp
.DS_Store

# Local data
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
/data/chroma/
/data/checkpoints.db
# ETL header-mapping cache is populated by `fleetwise-etl ingest`. Don't
# commit it -- a cache built from a run without a real LLM key memoizes
# nulls for non-canonical headers and would poison future runs with
# false hits. The empty `.gitkeep` keeps the dir present.
/data/etl-cache/*
!/data/etl-cache/.gitkeep

# Frontend (lands in Phase 9)
frontend/node_modules/
frontend/dist/
frontend/.vite/
